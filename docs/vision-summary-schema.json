{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Vision Summary Message (5-second window)",
  "type": "object",
  "required": [
    "device_id", "board_id", "seq", "timestamp", "interval_sec",
    "ots_count", "lts_count", "ots_demographics", "lts_demographics", "attention"
  ],
  "additionalProperties": false,
  "properties": {
    "device_id": { "type": "string", "minLength": 1 },
    "board_id": { "type": "string", "minLength": 1 },
    "seq": { "type": "integer", "minimum": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "interval_sec": { "type": "number", "exclusiveMinimum": 0 },
    "ots_count": { "type": "integer", "minimum": 0 },
    "lts_count": { "type": "integer", "minimum": 0 },
    "ots_demographics": { "$ref": "#/definitions/demographics" },
    "lts_demographics": { "$ref": "#/definitions/demographics" },
    "attention": {
      "type": "object",
      "required": ["avg_dwell_sec", "dwell_sum_sec", "dwell_distribution"],
      "additionalProperties": false,
      "properties": {
        "avg_dwell_sec": { "type": "number", "minimum": 0 },
        "dwell_sum_sec": { "type": "number", "minimum": 0 },
        "dwell_distribution": {
          "type": "object",
          "required": ["1_to_under_2s", "2_to_under_3s", "3_to_under_4s", "4s_and_over"],
          "additionalProperties": false,
          "properties": {
            "1_to_under_2s": { "type": "integer", "minimum": 0 },
            "2_to_under_3s": { "type": "integer", "minimum": 0 },
            "3_to_under_4s": { "type": "integer", "minimum": 0 },
            "4s_and_over": { "type": "integer", "minimum": 0 }
          }
        }
      }
    }
  },
  "definitions": {
    "ageBuckets": {
      "type": "object",
      "required": ["under10", "10s", "20s", "30s", "40s", "50s", "60plus"],
      "additionalProperties": false,
      "properties": {
        "under10": { "type": "integer", "minimum": 0 },
        "10s": { "type": "integer", "minimum": 0 },
        "20s": { "type": "integer", "minimum": 0 },
        "30s": { "type": "integer", "minimum": 0 },
        "40s": { "type": "integer", "minimum": 0 },
        "50s": { "type": "integer", "minimum": 0 },
        "60plus": { "type": "integer", "minimum": 0 }
      }
    },
    "genderDemographics": {
      "type": "object",
      "required": ["count", "age"],
      "additionalProperties": false,
      "properties": {
        "count": { "type": "integer", "minimum": 0 },
        "age": { "$ref": "#/definitions/ageBuckets" }
      }
    },
    "demographics": {
      "type": "object",
      "required": ["male", "female"],
      "additionalProperties": false,
      "properties": {
        "male": { "$ref": "#/definitions/genderDemographics" },
        "female": { "$ref": "#/definitions/genderDemographics" }
      }
    }
  }
}
